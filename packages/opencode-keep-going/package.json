{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "opencode-keep-going",
  "version": "0.1.0",
  "description": "OpenCode TUI plugin that sends a continue prompt when you press Enter on an empty input.",
  "type": "module",
  "main": "./dist/tui.js",
  "types": "./dist/tui.d.ts",
  "exports": {
    ".": {
      "types": "./dist/tui.d.ts",
      "import": "./dist/tui.js",
      "default": "./dist/tui.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "smoke": "node -e \"import('./dist/tui.js').then((m) => { if (!m.default?.tui) throw new Error('missing tui plugin export') })\"",
    "pack:dry-run": "npm pack --dry-run",
    "prepack": "npm run build && npm run smoke",
    "prepublishOnly": "npm run typecheck && npm run prepack"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "opencode-tui",
    "plugin",
    "continue",
    "ai"
  ],
  "author": "vimtor",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vimtor/opencode-plugins.git",
    "directory": "packages/opencode-keep-going"
  },
  "bugs": {
    "url": "https://github.com/vimtor/opencode-plugins/issues"
  },
  "homepage": "https://github.com/vimtor/opencode-plugins/tree/main/packages/opencode-keep-going#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.15.1",
    "typescript": "^5.9.3"
  }
}
